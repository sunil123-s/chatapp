{
    "installCommand" : "npm install --legacy-peer-deps",
    "version" : 2,
    "builds": [
        {
            "src" : "/src/server.js",
            "use" : "@vercel/node"
        },
        {
            "src" : "frontend/public/**/*",
            "use" : "@vercel/static"
        }
    ],
    "routes":[
      {
        "src": "/auth/(.*)",
        "dest": "/src/server.js"
      },
      {
        "src": "/chat/(.*)",
        "dest": "/src/server.js"
      },
      {
        "src": "/user/(.*)",
        "dest": "/src/server.js"
      },
      {
        "src": "/message/(.*)",
        "dest": "/src/server.js"
      },
      {
        "src": "/uploads/(.*)",
        "dest": "/src/public/uploads/$1"
      }
    ]
}   